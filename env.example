
#  VivaEventos – Variables de entorno
#  INSTRUCCIONES:
#    1. Copiar este archivo:  cp .env.example .env
#    2. Reemplazar TODOS los valores marcados con <CAMBIAR>
#    3. La contraseña debe de ser la misma para todos, en el grupo está.
#    4. NUNCA commitear el .env al repositorio

# --- PostgreSQL (base de datos de Keycloak) ------------------
KC_DB_NAME=keycloak_db
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=<CAMBIAR_por_password_seguro>
#Contraseña conjunta en el grupo.

# --- Administrador de Keycloak -------------------------------
# Solo se usa en el primer arranque para crear el super-admin
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=<CAMBIAR_por_password_seguro>
#pongan la misma contraseña aquí que el DB.

# --- Servidor -------------------------------------------------
# En desarrollo: localhost
# En staging/prod: el hostname real (ej. auth.vivaeventos.com)
KC_HOSTNAME=localhost
KC_HTTP_PORT=8080
#Este puerto es por defecto, pero probablemente lo tengan que cambiar porque estará en uso.

# --- Nivel de log (info | debug | warn | error) --------------
KC_LOG_LEVEL=info
